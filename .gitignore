# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/
env/

# --- Secrets / credentials (safety net — never commit) ---
.env
.env.*
*.key
*.pem
*secret*
*credential*
*token*.json

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/*
!.vscode/settings.json

# --- Node ---
node_modules/

# --- Logs / temp ---
*.log
*.tmp
tmp/

# --- 배포 스냅샷 (git history 로 rollback 가능, 별도 보관 불필요) ---
runs/

# --- 보드 소통 보고서 (로컬 단일수신함, git 추적 제외) — CMPA-223 ---
# review/ 는 보드(사람)가 로컬에서 읽는 보고서 누적함이지 코드 산출물이 아니다.
# 규약 문서(README)만 추적 유지하고 누적 보고서는 git 에 올리지 않는다.
review/
!review/README.md
